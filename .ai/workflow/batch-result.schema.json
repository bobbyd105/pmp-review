{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.pmp-review/schemas/batch-result.schema.json",
  "title": "Claude-Codex Batch Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature_id",
    "batch_id",
    "status",
    "summary",
    "changed_paths",
    "validation",
    "review_findings",
    "codex_attempts",
    "next_action"
  ],
  "properties": {
    "feature_id": { "type": "string", "minLength": 1 },
    "batch_id": { "type": "string", "pattern": "^B[0-9]{2,}$" },
    "status": {
      "type": "string",
      "enum": ["BATCH_COMPLETE", "REPAIR_REQUIRED", "HUMAN_REVIEW_REQUIRED"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "changed_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "result"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "result": { "type": "string", "enum": ["passed", "failed", "not_run"] },
          "notes": { "type": "string" }
        }
      }
    },
    "review_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "finding", "resolved"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "finding": { "type": "string", "minLength": 1 },
          "resolved": { "type": "boolean" }
        }
      }
    },
    "codex_attempts": { "type": "integer", "minimum": 0 },
    "checkpoint_message": { "type": ["string", "null"] },
    "blocker": { "type": ["string", "null"] },
    "next_action": {
      "type": "string",
      "enum": ["checkpoint", "fresh_repair_session", "stop_for_user"]
    }
  }
}
